{
    "swagger": "2.0",
    "info": {
        "title": "Proxy Service API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/api/v1/access/check": {
            "get": {
                "tags": [
                    "access"
                ],
                "summary": "Check IP access",
                "parameters": [
                    {
                        "type": "string",
                        "description": "IP address to evaluate. Defaults to the caller IP when omitted",
                        "name": "ip",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Captcha token for greylist verification",
                        "name": "captcha",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/core.AccessDecision"
                        }
                    }
                }
            }
        },
        "/api/v1/access/rules": {
            "get": {
                "tags": [
                    "access"
                ],
                "summary": "List IP access rules",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/httpapi.accessRuleView"
                            }
                        }
                    }
                }
            },
            "post": {
                "consumes": [
                    "application/json"
                ],
                "tags": [
                    "access"
                ],
                "summary": "Create IP access rule",
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/httpapi.accessRuleView"
                        }
                    }
                }
            }
        },
        "/api/v1/access/rules/{id}": {
            "delete": {
                "tags": [
                    "access"
                ],
                "summary": "Delete IP access rule",
                "responses": {
                    "204": {
                        "description": "No Content"
                    }
                }
            }
        },
        "/api/v1/cache": {
            "get": {
                "tags": [
                    "cache"
                ],
                "summary": "Cache snapshot",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/core.CacheSnapshot"
                        }
                    }
                }
            },
            "delete": {
                "tags": [
                    "cache"
                ],
                "summary": "Clear cache",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/api/v1/cache/invalidate": {
            "post": {
                "consumes": [
                    "application/json"
                ],
                "tags": [
                    "cache"
                ],
                "summary": "Invalidate cache",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/api/v1/dashboard/overview": {
            "get": {
                "tags": [
                    "dashboard"
                ],
                "summary": "Dashboard overview",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {

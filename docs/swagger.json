                        }
                    }
                }
            }
        },
        "/api/v1/monitoring": {
            "get": {
                "tags": [
                    "monitoring"
                ],
                "summary": "Monitoring data",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/core.MonitoringSnapshot"
                        }
                    }
                }
            }
        },
        "/api/v1/rate-limits": {
            "get": {
                "tags": [
                    "rate-limit"
                ],
                "summary": "Get rate limit configuration and violations",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/httpapi.rateLimitResponse"
                        }
                    }
                }
            },
            "put": {
                "consumes": [
                    "application/json"
                ],
                "tags": [
                    "rate-limit"
                ],
                "summary": "Update rate limit configuration",

                    "type": "string"
                },
                "reason": {
                    "type": "string"
                },
                "requiresCaptcha": {
                    "type": "boolean"
                },
                "ruleId": {
                    "type": "string"
                },
                "ruleType": {
                    "$ref": "#/definitions/core.AccessRuleType"
                }
            }
        },
        "core.AccessRuleType": {
            "type": "string",
            "enum": [
                "allow",
                "deny",
                "grey"
            ],
            "x-enum-varnames": [
                "AccessRuleAllow",
                "AccessRuleDeny",
                "AccessRuleGrey"
            ]
        },

                        }
                    }
                }
            }
        },
        "/api/v1/logs": {
            "get": {
                "tags": [
                    "logs"
                ],
                "summary": "Recent logs",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/httpapi.logsResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/logs/export": {
            "get": {
                "tags": [
                    "logs"
                ],
                "summary": "Export logs",
